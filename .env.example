# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/jyutcollab

# Session (nuxt-auth-utils) - at least 32 characters
NUXT_SESSION_PASSWORD=your-session-password-at-least-32-chars-long

# JWT Secret (生產環境必須設定，開發環境可省略)
JWT_SECRET=your-jwt-secret-at-least-32-chars-long

# OpenRouter API Key (for AI features)
OPENROUTER_API_KEY=sk-or-your-api-key
OPENROUTER_MODEL=deepseek-v4-flash

# Cloudinary（釋義配圖：上傳與優化，請填寫到 .env）
# 在 Cloudinary Dashboard → Settings → API Keys 可查看
NUXT_CLOUDINARY_CLOUD_NAME=your_cloud_name
NUXT_CLOUDINARY_API_KEY=your_api_key
NUXT_CLOUDINARY_API_SECRET=your_api_secret

# Google OAuth（Google Cloud Console → APIs & Services → Credentials）
# 建立 OAuth 2.0 Client ID，類型選「Web application」
# Authorized redirect URI 設定為：<site-url>/auth/google
NUXT_OAUTH_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# Site Configuration (dev: frontend + API on same port)
NUXT_PORT=3100
NUXT_PUBLIC_SITE_URL=http://localhost:3100
NUXT_PUBLIC_SITE_NAME=JyutCollab v2
